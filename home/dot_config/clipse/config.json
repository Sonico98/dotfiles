{
    "allowDuplicates": false,
    "historyFile": "clipboard_history.json",
    "maxHistory": 100,
    "logFile": "clipse.log",
    "themeFile": "custom_theme.json",
    "tempDir": "tmp_files",
    "keyBindings": {
        "choose": "enter",
        "clearSelected": "S",
        "down": "j",
        "end": "end",
        "filter": "/",
        "home": "home",
        "more": "?",
        "nextPage": "l",
        "prevPage": "h",
        "preview": " ",
        "quit": "esc",
        "remove": "x",
        "selectDown": "ctrl+down",
        "selectSingle": "s",
        "selectUp": "ctrl+up",
        "togglePin": "p",
        "togglePinned": "tab",
        "up": "k",
        "yankFilter": "ctrl+s"
    },
    "imageDisplay": {
        "type": "kitty",
        "scaleX": 20,
        "scaleY": 20,
        "heightCut": 10
    },
	"excludedApps": [
        "1Password",
        "Bitwarden",
        "KeePassXC",
        "LastPass",
        "Dashlane",
        "Password Safe",
        "Keychain Access"
    ]
}
